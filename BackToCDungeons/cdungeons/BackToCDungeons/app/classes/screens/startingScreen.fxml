<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane id="startingScreenPane" fx:id="startingScreenPane" prefHeight="600.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dungeons.Controllers.OptionsNStartingController">

    <children>

        <Label id="mainNAME" layoutX="110.0" layoutY="122.0" text="WELCOME TO LABDUNG">
        </Label>

        <Label id="gameVersion" layoutX="664.0" layoutY="580.0" text="SCHOOL PROJECT DEMO 0.0.1">
            <font>
                <Font size="9.0" />
            </font>
        </Label>

        <AnchorPane layoutX="270.0" layoutY="255.0" prefHeight="227.0" prefWidth="261.0">

            <children>
                <Button styleClass="nonGameSelector" layoutX="35.0" layoutY="14.0" onAction="#handleButton1" prefHeight="55.0" prefWidth="160.0" text="PLAY" />

                <Button styleClass="nonGameSelector" layoutX="35.0" layoutY="86.0" onAction="#handleButton2" prefHeight="55.0" prefWidth="160.0" text="CREIDTS" />

                <Button styleClass="nonGameSelector" layoutX="35.0" layoutY="158.0" onAction="#handleButton3" prefHeight="55.0" prefWidth="160.0" text="EXIT" />
            </children>

        </AnchorPane>

    </children>
</Pane>
